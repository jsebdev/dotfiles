
[user]
	name = Sebastian Caicedo
	email = jsebdev@gmail.com

[alias]
	logad = log --oneline --graph --all --decorate
	logadu = log --oneline --graph --all --decorate --pretty=format:'%h (%an) %s'
	logd = log --oneline --graph --decorate
	logdu = log --oneline --graph --decorate --pretty=format:'%h (%an) %s'

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	editor = nvim
