
[user]
	name = Sebastian Caicedo
	email = jsebdev@gmail.com

[alias]
	logad = log --oneline --graph --all --decorate
	logadu = log --oneline --graph --all --decorate --pretty=format:'%h (%an) %s'
	logd = log --oneline --graph --decorate
	logdu = log --oneline --graph --decorate --pretty=format:'%h (%an) %s'
	logdd = log --oneline --graph --decorate --pretty=format:'%h (%ad) %s' --date=short

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	editor = nvim
	ignorecase = false
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    keep-plus-minus-markers = true  # show +/-

[merge]
    conflictStyle = zdiff3
